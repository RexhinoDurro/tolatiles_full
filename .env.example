# ─────────────────────────────────────────────────────────────────────────────
# .env.example — add ALL of these to your Infisical project.
# Create two environments in Infisical: "dev" and "prod".
# Never commit real values here or in any .env file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-with-50-char-random-string
DJANGO_DEBUG=False                   # True in dev environment

# ── Database ──────────────────────────────────────────────────────────────────
# Dev: Docker builds DATABASE_URL from POSTGRES_PASSWORD (see docker-compose.yml)
# Prod: full connection string for the VPS postgres instance
POSTGRES_PASSWORD=devpassword        # dev only — used by docker-compose
DATABASE_URL=postgres://tolatiles:password@localhost:5432/tolatiles  # prod

# ── Redis / Celery ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_HOST=localhost                 # docker-compose overrides to "redis"

# ── Email (AWS WorkMail) ──────────────────────────────────────────────────────
WORKMAIL_PASS=your-workmail-smtp-password

# ── Google OAuth (Search Console) ────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Google Ads ────────────────────────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=menitola@tolatiles.com

# ── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_IMAGE_API_KEY=

# ── Cloudflare Turnstile ──────────────────────────────────────────────────────
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# ── Misc ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://tolatiles.com   # http://localhost:3000 in dev
